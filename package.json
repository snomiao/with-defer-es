{
  "name": "with-defer-es",
  "version": "1.0.4",
  "description": "Run a function with an injected go-like defer helper with ESModule supported",
  "keywords": [
    "defer",
    "golang",
    "release",
    "resource",
    "esm"
  ],
  "homepage": "https://github.com/snomiao/with-defer-es#readme",
  "bugs": {
    "url": "https://github.com/snomiao/with-defer-es/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snomiao/with-defer-es.git"
  },
  "license": "MIT",
  "author": "snomiao",
  "type": "module",
  "exports": {
    "import": "./dist/index.js",
    "types": "./index.ts"
  },
  "main": "dist/index.js",
  "module": "index.ts",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && esbuild --bundle index.ts --outdir=dist --sourcemap --format=esm",
    "prerelease": "bun run build && bun run test",
    "release": "bunx standard-version && git push --follow-tags && npm publish",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.1.6",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.4"
  }
}
